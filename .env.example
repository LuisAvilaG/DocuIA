# ============================================================
# DocuIA — Environment Variables
# Copy to .env.local for local development
# ============================================================

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=DocuIA

# --- PostgreSQL (new database — separate from MeraIA) ---
DATABASE_URL=postgresql://docuia_user:change_me@localhost:5432/docuia

# --- Encryption (credentials at rest) ---
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=change_me_64_char_hex_string_generate_with_openssl_rand_hex_32

# --- JWT Auth ---
JWT_SECRET=change_me_min_32_chars_random_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- Google Gemini AI ---
GOOGLE_API_KEY=
GEMINI_EXTRACT_PRIMARY_MODEL=gemini-2.5-flash
GEMINI_EXTRACT_SECONDARY_MODEL=gemini-2.5-pro
GEMINI_EXTRACT_MAX_CHARS=65000

# --- Workflow pipeline ---
# Minimum confidence (0–1) to auto-process without human review. Default: 0.85
WORKFLOW_AUTO_PROCESS_THRESHOLD=0.85

# --- MinIO (document storage) ---
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change_me
MINIO_BUCKET=docuia-documents
MINIO_USE_SSL=false

# --- Stripe (billing) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Resend (email) ---
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@docuia.com
RESEND_FROM_NAME=DocuIA

# --- Internal cron authentication ---
# Header sent by your cron scheduler: X-Cron-Secret: <value>
CRON_SECRET=change_me_min_32_chars_random_string

# --- Platform Admin (seed) ---
# Used only on first run to create the super-admin account
PLATFORM_ADMIN_EMAIL=admin@docuia.com
PLATFORM_ADMIN_PASSWORD=change_me_strong_password
