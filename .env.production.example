# ============================================================
# DocuIA — Plantilla de variables de PRODUCCIÓN (EasyPanel)
# Copia estas claves a las variables de entorno de tu host.
# Genera los secretos con:  node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
# NO commitees este archivo con valores reales.
# ============================================================

NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://tu-dominio.com

# --- Base de datos (usa el host real, NO 'localhost'; fuerza TLS) ---
DATABASE_URL=postgresql://user:pass@db-host:5432/docuia?sslmode=require
DATABASE_SSL=true
# DATABASE_SSL_NO_VERIFY=true   # solo si el cert es self-signed

# --- Secretos (≥32 chars; genera valores únicos) ---
JWT_SECRET=__genera_uno__
REFRESH_SECRET=__genera_uno_distinto__
# ⚠️ ENCRYPTION_KEY: si YA hay credenciales NetSuite cifradas en la DB, CONSERVA
# la clave existente. Cambiarla vuelve indescifrables esas credenciales.
ENCRYPTION_KEY=__64_hex_chars__

# --- Cron interno (header X-Cron-Secret) ---
CRON_SECRET=__genera_uno__

# --- MinIO / almacenamiento (sin defaults inseguros) ---
MINIO_ENDPOINT=minio-host
MINIO_PORT=9000
MINIO_USE_SSL=true
MINIO_ACCESS_KEY=__requerido__
MINIO_SECRET_KEY=__requerido__
MINIO_BUCKET=docuia

# --- IA / correo ---
GEMINI_API_KEY=__tu_api_key__
RESEND_API_KEY=__tu_api_key__

# --- Timeouts / cola (opcionales; defaults razonables) ---
GEMINI_TIMEOUT_MS=90000
NETSUITE_TIMEOUT_MS=30000
STUCK_DOC_MINUTES=15
